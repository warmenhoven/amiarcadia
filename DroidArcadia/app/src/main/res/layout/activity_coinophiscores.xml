<?xml version="1.0" encoding="iso-8859-1"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#444455"
    android:gravity="center_horizontal"
    android:id="@+id/hiscores_root"
    android:fillViewport="true">
        
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:textSize="24sp"
        android:text="@string/coinophiscores"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:gravity="center_horizontal"
    />

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="fill_vertical"
        android:gravity="fill_vertical"
        android:background="#444455">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="fill_vertical"
            android:gravity="fill_vertical"
            android:layout_marginLeft="10dp"
            android:background="#444455">
            <ImageView
                android:layout_width="16sp"
                android:layout_height="16sp"
                android:layout_weight="1"
                android:src="@drawable/astrowars"
            />
            <ImageView
                android:layout_width="16sp"
                android:layout_height="16sp"
                android:layout_weight="1"
                android:src="@drawable/galaxia"
            />
            <ImageView
                android:layout_width="16sp"
                android:layout_height="16sp"
                android:layout_weight="1"
                android:src="@drawable/laserbattle"
            />
            <ImageView
                android:layout_width="16sp"
                android:layout_height="16sp"
                android:layout_weight="1"
                android:src="@drawable/laserbattle"
            />
            <ImageView
                android:layout_width="16sp"
                android:layout_height="16sp"
                android:layout_weight="1"
                android:src="@drawable/malzak"
            />
            <ImageView
                android:layout_width="16sp"
                android:layout_height="16sp"
                android:layout_weight="1"
                android:src="@drawable/malzak"
            />
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginLeft="10dp"
            android:gravity="left"
            android:background="#444455">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="Astro Wars"
                android:gravity="left"
            />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="Galaxia"
                android:gravity="left"
            />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="Laser Battle"
                android:gravity="left"
            />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="Lazarian"
                android:gravity="left"
            />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="Malzak 1"
                android:gravity="left"
            />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="Malzak 2"
                android:gravity="left"
            />
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginRight="10dp"
            android:gravity="right"
            android:background="#444455">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/hs_1"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="-"
                android:gravity="right"
            />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/hs_2"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="-"
                android:gravity="right"
            />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/hs_3"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="-"
                android:gravity="right"
            />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/hs_4"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="-"
                android:gravity="right"
            />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/hs_5"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="-"
                android:gravity="right"
            />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/hs_6"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:text="-"
                android:gravity="right"
            />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/clearhighscores"
            android:id="@+id/button_clearhs"
            android:padding="5dp"
            android:background="#ffcc99"
            android:gravity="center"
        />
    </LinearLayout>
        
</LinearLayout>
