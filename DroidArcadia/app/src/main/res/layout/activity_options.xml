            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/lock"
            android:id="@+id/switch_lock"
            android:padding="10dp"
            android:background="#6655ff"
            android:gravity="left"
            android:layout_marginBottom="1dp"
            android:thumbTint="@color/black"
        />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:id="@+id/label_stretch"
            android:padding="10dp"
            android:background="#6655ff"
            android:gravity="left"
        />
        <SeekBar
            android:id="@+id/seekbar_stretch"
            style="@style/Widget.AppCompat.SeekBar.Discrete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="0"
            android:max="3"
            android:progress="3"
            android:thumbTint="@color/black"
            android:progressTint="@color/black"
            android:background="#7766ff"
            android:layout_marginBottom="1dp"
        />

        <Switch
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/dejitterhorizons"
            android:id="@+id/switch_dejitter"
            android:padding="10dp"
            android:background="#00cc00"
            android:gravity="left"
            android:layout_marginBottom="1dp"
            android:thumbTint="@color/black"
        />

        <Switch
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/enhancedskies"
            android:id="@+id/switch_skies"
            android:padding="10dp"
            android:background="#00cc00"
            android:gravity="left"
            android:layout_marginBottom="1dp"
            android:thumbTint="@color/black"
