            android:layout_height="wrap_content"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:textSize="24sp"
            android:text="@string/commandsplusoptions"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
        />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/reset2"
            android:id="@+id/button_reset"
            android:padding="10dp"
            android:background="#ddcccc"
            android:gravity="left"
            android:layout_marginBottom="1dp"
        />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/quickload"
            android:id="@+id/button_quickload"
            android:padding="10dp"
            android:background="#ddcccc"
            android:gravity="left"
            android:layout_marginBottom="1dp"
        />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/quicksave"
            android:id="@+id/button_quicksave"
            android:padding="10dp"
            android:background="#ddcccc"
            android:gravity="left"
            android:layout_marginBottom="1dp"
        />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/savescreenshot"
            android:id="@+id/button_screenshot"
            android:padding="10dp"
            android:background="#ddcccc"
            android:gravity="left"
            android:layout_marginBottom="1dp"
        />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
