            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:id="@+id/button_colours"
            android:padding="10dp"
            android:background="#ffaaaa"
            android:gravity="left"
            android:layout_marginBottom="1dp"
        />

        <Switch
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/artefacts"
            android:id="@+id/switch_artefacts"
            android:padding="10dp"
            android:background="#ffaaaa"
            android:gravity="left"
            android:layout_marginBottom="1dp"
            android:thumbTint="@color/black"
        />

        <Switch
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/darkenbg"
            android:id="@+id/switch_darkenbg"
            android:padding="10dp"
            android:background="#ffaaaa"
            android:gravity="left"
            android:layout_marginBottom="1dp"
            android:thumbTint="@color/black"
        />

        <Switch
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/flagline"
            android:id="@+id/switch_flagline"
            android:padding="10dp"
            android:background="#ffaaaa"
            android:gravity="left"
            android:layout_marginBottom="1dp"
            android:thumbTint="@color/black"
        />

        <Switch
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="@string/linebased"
            android:id="@+id/switch_linebased"
            android:padding="10dp"
            android:background="#88ff88"
            android:gravity="left"
            android:layout_marginBottom="1dp"
            android:thumbTint="@color/black"
        />

        <Switch
