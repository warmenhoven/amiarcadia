IDR_MAINMENU_SPA MENU DISCARDABLE 
BEGIN
    POPUP "Archivo (&F)"
    BEGIN
        MENUITEM "Reiniciar el juego (&G)\tF5, Alt+R", ID_FILE_RESET
        MENUITEM "Saltar al sistema de E/S básico BIOS (&J)\tCtrl+Comma, Shift+F5", 
                                                ID_FILE_RESETTOMONITOR
        MENUITEM "Reinicializar la máquina (&T)", ID_FILE_REINITIALIZE
        MENUITEM SEPARATOR
        MENUITEM "Abrir el jueg&o/estado/grabación...\tCtrl+O", ID_FILE_OPEN
        MENUITEM "&Revertir\tCtrl+R",           ID_FILE_REVERT
        MENUITEM "Carga rápida del estado (&Q)\tCtrl+Shift+9, Alt+L", 
                                                ID_FILE_QUICKLOAD
        MENUITEM SEPARATOR
        MENUITEM "Guardar el e&stado como...\tCtrl+S", ID_FILE_SAVESNP
        POPUP "Guardar la image&n de la pantalla como"
        BEGIN
            MENUITEM "&BMP...\tCtrl+Y",             ID_FILE_SAVEBMP
            MENUITEM "&GIF...",                     ID_FILE_SAVEGIF
            MENUITEM "IFF &ACBM...",                ID_FILE_SAVEACBM
            MENUITEM "IFF &ILBM...\tCtrl+_",        ID_FILE_SAVEILBM
            MENUITEM "PC&X...",                     ID_FILE_SAVEPCX
            MENUITEM "&PNG...",                     ID_FILE_SAVEPNG
            MENUITEM "&TIFF...",                    ID_FILE_SAVETIFF
            MENUITEM SEPARATOR
            MENUITEM "A&SCII text...",              ID_FILE_SAVEASCII
            MENUITEM "AS&M...",                     ID_FILE_SAVEASM
        END
        MENUITEM "Grabación rápida del estado (&U)\tCtrl+Shift+0, Alt+S", 
                                                ID_FILE_QUICKSAVE
        MENUITEM SEPARATOR
        MENUITEM "&Auditoría de los juegos...", ID_FILE_AUDIT
        MENUITEM "Registrar los tipos de fichero... (&Y)", ID_FILE_REGISTER
        MENUITEM SEPARATOR
        MENUITEM "M&inimizar en la barra de tareas\tCtrl+F12", 
                                                ID_FILE_ICONIFY
        MENUITEM "Salir (&X)\tShift+Esc",       ID_FILE_EXIT
    END
    POPUP "&Editar"
    BEGIN
        MENUITEM "&Memoria...\tCtrl+Shift+3",   ID_TOOLS_MEMORY
        MENUITEM "&Paleta...\tCtrl+Shift+4",    ID_TOOLS_PALETTE
        MENUITEM "&Screen",                     ID_TOOLS_SCREENEDITOR
        MENUITEM "Spr&ites/characters...\tCtrl+Shift+5", ID_TOOLS_SPRITES
        MENUITEM SEPARATOR
        MENUITEM "&Copiar la imagen de la pantalla\tCtrl+C", ID_EDIT_COPY
        MENUITEM "Copy all &text",              ID_EDIT_COPYTEXT
        MENUITEM "&Pegar el texto\tCtrl+V",     ID_EDIT_PASTETEXT
        MENUITEM SEPARATOR
        MENUITEM "Portapap&eles vacío",         ID_EDIT_EMPTYCLIPBOARD
    END
    POPUP "&Vista"
    BEGIN
        MENUITEM "Tabla de plusmarcas... (&H)\tCtrl+Shift+1", 
                                                ID_VIEW_HISCORES
        MENUITEM SEPARATOR
        MENUITEM "żInterfaz de línea de comandos? (&G)\tCtrl+/", 
                                                ID_VIEW_DEBUGGER
        MENUITEM "żBarra de &menú?\tCtrl+M",    ID_VIEW_MENU
        MENUITEM "ż&Puntero?\tCtrl+X",          ID_VIEW_POINTER
        MENUITEM "żL&istado lateral?\tCtrl+I",  ID_VIEW_SIDEBAR
        MENUITEM "żBarra de estado? (&W)\tCtrl+D", ID_VIEW_STATUS
        MENUITEM "żBarra de &título?\tCtrl+E",  ID_VIEW_TITLE
        MENUITEM "żBarra de herramientas? (&L)\tCtrl+H", ID_VIEW_TOOL
        MENUITEM SEPARATOR
        MENUITEM "żJuegos internos? (&B)",      ID_VIEW_BUILTIN
        POPUP "Or&denar el listado lateral por"
        BEGIN
            MENUITEM "&Nombre del juego/directorio", ID_SORTBY_NAME
            MENUITEM "&Máquina",                    ID_SORTBY_MACHINE
        END
        MENUITEM SEPARATOR
        POPUP "Mostrar velocidad como (&X)"
        BEGIN
            MENUITEM "&Fotogramas por segundo",     ID_INDICATOR_FPS
            MENUITEM "&kHz",                        ID_INDICATOR_KHZ
            MENUITEM "&Porcentaje",                 ID_INDICATOR_PERCENT
        END
    END
    POPUP "&Macro"
    BEGIN
        MENUITEM "Comenza&r la grabación...\tCtrl+Shift+[", 
                                                ID_MACRO_STARTRECORDING
        MENUITEM "Reiniciar la re&producción",  ID_MACRO_RESTARTPLAYBACK
        MENUITEM "De&tener la grabación/reproducción\tCtrl+Shift+]", 
                                                ID_MACRO_STOP
        MENUITEM SEPARATOR
        MENUITEM "żCyc&lica?",                  ID_MACRO_LOOP
        MENUITEM SEPARATOR
        POPUP "Generate &animations"
        BEGIN
            MENUITEM "&GIF",                        ID_MACRO_GIF
            MENUITEM "&IFF ANIM",                   ID_MACRO_IFFANIMS
            MENUITEM "&MNG",                        ID_MACRO_MNG
            MENUITEM "&PNG",                        ID_MACRO_APNG
        END
        POPUP "Generate &sound files"
        BEGIN
            MENUITEM "IFF &8SVX/16SV",              ID_MACRO_8SVX
            MENUITEM "IFF &AIFF (Audio IFF)",       ID_MACRO_AIFF
            MENUITEM "IFF &SMUS",                   ID_MACRO_SMUS
            MENUITEM "&MIDI",                       ID_MACRO_MIDI
            MENUITEM "&PSG",                        ID_MACRO_PSGS
            MENUITEM "&WAV",                        ID_MACRO_WAV
            MENUITEM "&YM",                         ID_MACRO_YM
        END
        MENUITEM "&Generate during playback?",  ID_MACRO_GENERATE
        MENUITEM SEPARATOR
        MENUITEM "Ejecutar un guión RE&XX...\tCtrl+.", ID_MACRO_RUNREXX
        MENUITEM "R&epita el último guión\tCtrl+Shift+.", 
                                                ID_MACRO_REPEATREXX
    END
    POPUP "&Debug"
    BEGIN
        POPUP "&General"
        BEGIN
            MENUITEM """<message>",                 ID_DEBUG_QUOTES
            MENUITEM "CLEARCOV",                    ID_DEBUG_CLEARCOV
            MENUITEM "CLS",                         ID_DEBUG_CLS
            MENUITEM "H|HELP|? [<page>]",           ID_DEBUG_HELP
            MENUITEM "SAY|SPEAK|SPK <message>",     ID_DEBUG_SAY
            MENUITEM "SYS|SYSTEM",                  ID_DEBUG_SYSTEM
        END
        POPUP "&File"
        BEGIN
            MENUITEM "*<command>",                  ID_DEBUG_ASTERISK
            MENUITEM "ASM <filename>",              ID_DEBUG_ASM
            MENUITEM "DISGAME [<start-addr> <end-addr>] [<filename>]", 
                                                    ID_DEBUG_DISGAME
            MENUITEM "ED|EDIT <filename>",          ID_DEBUG_EDIT
            MENUITEM "LOADBIN <start-addr> <filename>", ID_DEBUG_LOAD
            MENUITEM "SAVEAOF|SAVEEOF <start-addr> <end-addr> [<filename> [<game-start> [<block-size>]]]", 
                                                    ID_DEBUG_SAVEAOF
            MENUITEM "SAVEBIN <start-addr> <end-addr> <filename>", 
                                                    ID_DEBUG_SAVE
            MENUITEM "SAVEBPNF <start-addr> <end-addr> <filename>", 
                                                    ID_DEBUG_SAVEBPNF
            MENUITEM "SAVECMD|SAVEIMAG|SAVEMOD <start-addr> <end-addr> [<filename> [<game-start>]]", 
                                                    ID_DEBUG_SAVECMD
            MENUITEM "SAVEHEX <start-addr> <end-addr> <filename>", 
                                                    ID_DEBUG_SAVEHEX
            MENUITEM "SAVESMS <end-addr> <filename>", ID_DEBUG_SAVESMS
            MENUITEM "SAVETVC <start-addr> <end-addr> [<filename> [<game-start>]]", 
                                                    ID_DEBUG_SAVETVC
        END
        POPUP "Dis&k"
        BEGIN
            MENUITEM "DEL|DELETE <filename>",       ID_DEBUG_DEL
            MENUITEM "DIR|LD|LDIR",                 ID_DEBUG_DIR
            MENUITEM "EXTRACT [<filename>]",        ID_DEBUG_EXTRACT
            MENUITEM "INJECT <filename>",           ID_DEBUG_INJECT
            MENUITEM "REN|RENAME <oldname> <newname>", ID_DEBUG_REN
            MENUITEM SEPARATOR
            MENUITEM "DRIVE 0",                     ID_DEBUG_DRIVE_0
            MENUITEM "DRIVE 1",                     ID_DEBUG_DRIVE_1
            MENUITEM "DRIVE 2",                     ID_DEBUG_DRIVE_2
            MENUITEM "DRIVE 3",                     ID_DEBUG_DRIVE_3
        END
        POPUP "&Edit"
        BEGIN
            MENUITEM "DOKE <address> [<value>]",    ID_DEBUG_DOKE
            MENUITEM "E|POKE [<address> [<value>]]", ID_DEBUG_POKE
            MENUITEM "FPOKE <address> <value>",     ID_DEBUG_FPOKE
            MENUITEM "WRITEPORT <port>|CTRL|DATA <value>", 
                                                    ID_DEBUG_WRITEPORT
        END
        POPUP "&View"
        BEGIN
            MENUITEM "= [<address>]",               ID_DEBUG_EQUALS
            MENUITEM "COVER [<reporttype>]",        ID_DEBUG_COVER
            MENUITEM "D|PEEK <start-addr> [<end-addr>]", ID_DEBUG_PEEK
            MENUITEM "DIS [<start-addr> [<end-addr>]]", ID_DEBUG_DIS
            MENUITEM "ERROR <number>",              ID_DEBUG_ERROR
            MENUITEM "FPEEK <start-addr> [<end-addr>]", ID_DEBUG_FPEEK
            MENUITEM "HISTORY",                     ID_DEBUG_HISTORY
            MENUITEM "IM [<start-addr> <end-addr>] [<filename>]", 
                                                    ID_DEBUG_IM
            MENUITEM "READPORT <port>|CTRL|DATA",   ID_DEBUG_READPORT
            MENUITEM SEPARATOR
