/////////////////////////////////////////////////////////////////////////////
// French (France) resources

#if !defined(AFX_RESOURCE_DLL) || defined(AFX_TARG_FRA)
#ifdef _WIN32
LANGUAGE LANG_FRENCH, SUBLANG_FRENCH
#pragma code_page(1252)
#endif //_WIN32

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINMENU_FRA MENU DISCARDABLE 
BEGIN
    POPUP "&Fichier"
    BEGIN
        MENUITEM "Redemarrer le Jeu (&G)\tF5, Alt+R", ID_FILE_RESET
        MENUITEM "Sauter vers le BIOS (&J)\tCtrl+Comma, Shift+F5", 
                                                ID_FILE_RESETTOMONITOR
        MENUITEM "Réini&tialiser la Machine",   ID_FILE_REINITIALIZE
        MENUITEM SEPARATOR
        MENUITEM "&Ouvrir...\tCtrl+O",          ID_FILE_OPEN
        MENUITEM "&Retablir\tCtrl+R",           ID_FILE_REVERT
        MENUITEM "Chargement d'Etat Rapide (&Q)\tCtrl+Shift+9, Alt+L", 
                                                ID_FILE_QUICKLOAD
        MENUITEM SEPARATOR
        MENUITEM "&Sauvegarder le Etat Sous...\tCtrl+S", ID_FILE_SAVESNP
        POPUP "Sauvegarder u&ne Capture d'Ecran Sous"
        BEGIN
            MENUITEM "&BMP...\tCtrl+Y",             ID_FILE_SAVEBMP
            MENUITEM "&GIF...",                     ID_FILE_SAVEGIF
            MENUITEM "IFF &ACBM...",                ID_FILE_SAVEACBM
            MENUITEM "IFF &ILBM...\tCtrl+_",        ID_FILE_SAVEILBM
            MENUITEM "PC&X...",                     ID_FILE_SAVEPCX
            MENUITEM "&PNG...",                     ID_FILE_SAVEPNG
            MENUITEM "&TIFF...",                    ID_FILE_SAVETIFF
            MENUITEM SEPARATOR
            MENUITEM "A&SCII text...",              ID_FILE_SAVEASCII
            MENUITEM "AS&M...",                     ID_FILE_SAVEASM
        END
        MENUITEM "Sauvegarde d'Etat Rapide (&U)\tCtrl+Shift+0, Alt+S", 
                                                ID_FILE_QUICKSAVE
        MENUITEM SEPARATOR
        MENUITEM "&Auditer les Jeux",           ID_FILE_AUDIT
        MENUITEM "Registres des T&ypes de Fichier...", ID_FILE_REGISTER
        MENUITEM SEPARATOR
        MENUITEM "&Iconifier\tCtrl+F12",        ID_FILE_ICONIFY
        MENUITEM "Quitter (&X)\tShift+Esc",     ID_FILE_EXIT
    END
    POPUP "&Edition"
    BEGIN
        MENUITEM "&Memoire...\tCtrl+Shift+3",   ID_TOOLS_MEMORY
        MENUITEM "&Palette...\tCtrl+Shift+4",   ID_TOOLS_PALETTE
        MENUITEM "&Screen",                     ID_TOOLS_SCREENEDITOR
        MENUITEM "Spr&ites/characters...\tCtrl+Shift+5", ID_TOOLS_SPRITES
        MENUITEM SEPARATOR
        MENUITEM "&Copier une Capture d'Ecran\tCtrl+C", ID_EDIT_COPY
        MENUITEM "Copy all &text",              ID_EDIT_COPYTEXT
        MENUITEM "Coller le Texte (&P)\tCtrl+V", ID_EDIT_PASTETEXT
        MENUITEM SEPARATOR
        MENUITEM "Vid&er le Presse Papier",     ID_EDIT_EMPTYCLIPBOARD
    END
    POPUP "&Visualiser"
    BEGIN
        MENUITEM "Tableau des Meilleurs scores... (&H)\tCtrl+Shift+1", 
                                                ID_VIEW_HISCORES
        MENUITEM SEPARATOR
        MENUITEM "Debu&geur?\tCtrl+/",          ID_VIEW_DEBUGGER
        MENUITEM "Barre de &Menu?\tCtrl+M",     ID_VIEW_MENU
        MENUITEM "&Pointeur?\tCtrl+X",          ID_VIEW_POINTER
        MENUITEM "Barre Laterale? (&I)?\tCtrl+I", ID_VIEW_SIDEBAR
        MENUITEM "Barre d'Etat? (&W)\tCtrl+D",  ID_VIEW_STATUS
        MENUITEM "Barre de &Titre?\tCtrl+E",    ID_VIEW_TITLE
        MENUITEM "Barre d'Outi&ls?\tCtrl+H",    ID_VIEW_TOOL
        MENUITEM SEPARATOR
        MENUITEM "Jeux Integres? (&B)",         ID_VIEW_BUILTIN
        POPUP "Trier la Barre Laterale par (&D)"
        BEGIN
            MENUITEM "&Nom du Jeu/Repertoire",      ID_SORTBY_NAME
            MENUITEM "&Machine",                    ID_SORTBY_MACHINE
        END
        MENUITEM SEPARATOR
        POPUP "Voir la Vitesse en (&X)"
        BEGIN
            MENUITEM "Images par Seconde (&F)",     ID_INDICATOR_FPS
            MENUITEM "&kHz",                        ID_INDICATOR_KHZ
            MENUITEM "&Pourcentage",                ID_INDICATOR_PERCENT
        END
    END
    POPUP "&Macro"
    BEGIN
        MENUITEM "Dema&rrer l'Enregistrement...\tCtrl+Shift+[", 
                                                ID_MACRO_STARTRECORDING
        MENUITEM "Redemarrer le &Playback",     ID_MACRO_RESTARTPLAYBACK
        MENUITEM "Arre&ter l'Enregistrement/Playback\tCtrl+Shift+]", 
                                                ID_MACRO_STOP
        MENUITEM SEPARATOR
        MENUITEM "Bouc&le?",                    ID_MACRO_LOOP
        MENUITEM SEPARATOR
        POPUP "Generate &animations"
        BEGIN
            MENUITEM "&GIF",                        ID_MACRO_GIF
            MENUITEM "&IFF ANIM",                   ID_MACRO_IFFANIMS
            MENUITEM "&MNG",                        ID_MACRO_MNG
            MENUITEM "&PNG",                        ID_MACRO_APNG
        END
        POPUP "Generate &sound files"
        BEGIN
            MENUITEM "IFF &8SVX/16SV",              ID_MACRO_8SVX
            MENUITEM "IFF &AIFF (Audio IFF)",       ID_MACRO_AIFF
            MENUITEM "IFF &SMUS",                   ID_MACRO_SMUS
            MENUITEM "&MIDI",                       ID_MACRO_MIDI
            MENUITEM "&PSG",                        ID_MACRO_PSGS
            MENUITEM "&WAV",                        ID_MACRO_WAV
            MENUITEM "&YM",                         ID_MACRO_YM
        END
        MENUITEM "&Generate during playback?",  ID_MACRO_GENERATE
        MENUITEM SEPARATOR
        MENUITEM "Lancer un script RE&XX...\tCtrl+.", ID_MACRO_RUNREXX
        MENUITEM "Répét&er le dernier script\tCtrl+Shift+.", 
                                                ID_MACRO_REPEATREXX
    END
    POPUP "&Debug"
    BEGIN
        POPUP "&General"
        BEGIN
            MENUITEM """<message>",                 ID_DEBUG_QUOTES
            MENUITEM "CLEARCOV",                    ID_DEBUG_CLEARCOV
            MENUITEM "CLS",                         ID_DEBUG_CLS
            MENUITEM "H|HELP|? [<page>]",           ID_DEBUG_HELP
            MENUITEM "SAY|SPEAK|SPK <message>",     ID_DEBUG_SAY
            MENUITEM "SYS|SYSTEM",                  ID_DEBUG_SYSTEM
        END
        POPUP "&Fichier"
        BEGIN
            MENUITEM "*<command>",                  ID_DEBUG_ASTERISK
            MENUITEM "ASM <filename>",              ID_DEBUG_ASM
            MENUITEM "DISGAME [<start-addr> <end-addr>] [<filename>]", 
                                                    ID_DEBUG_DISGAME
            MENUITEM "ED|EDIT <filename>",          ID_DEBUG_EDIT
            MENUITEM "LOADBIN <start-addr> <filename>", ID_DEBUG_LOAD
            MENUITEM "SAVEAOF|SAVEEOF <start-addr> <end-addr> [<filename> [<game-start> [<block-size>]]]", 
                                                    ID_DEBUG_SAVEAOF
            MENUITEM "SAVEBIN <start-addr> <end-addr> <filename>", 
                                                    ID_DEBUG_SAVE
            MENUITEM "SAVEBPNF <start-addr> <end-addr> <filename>", 
                                                    ID_DEBUG_SAVEBPNF
            MENUITEM "SAVECMD|SAVEIMAG|SAVEMOD <start-addr> <end-addr> [<filename> [<game-start>]]", 
                                                    ID_DEBUG_SAVECMD
            MENUITEM "SAVEHEX <start-addr> <end-addr> <filename>", 
                                                    ID_DEBUG_SAVEHEX
            MENUITEM "SAVESMS <end-addr> <filename>", ID_DEBUG_SAVESMS
            MENUITEM "SAVETVC <start-addr> <end-addr> [<filename> [<game-start>]]", 
                                                    ID_DEBUG_SAVETVC
        END
        POPUP "Dis&k"
        BEGIN
            MENUITEM "DEL|DELETE <filename>",       ID_DEBUG_DEL
            MENUITEM "DIR|LD|LDIR",                 ID_DEBUG_DIR
            MENUITEM "EXTRACT [<filename>]",        ID_DEBUG_EXTRACT
            MENUITEM "INJECT <filename>",           ID_DEBUG_INJECT
            MENUITEM "REN|RENAME <oldname> <newname>", ID_DEBUG_REN
            MENUITEM SEPARATOR
            MENUITEM "DRIVE 0",                     ID_DEBUG_DRIVE_0
            MENUITEM "DRIVE 1",                     ID_DEBUG_DRIVE_1
            MENUITEM "DRIVE 2",                     ID_DEBUG_DRIVE_2
            MENUITEM "DRIVE 3",                     ID_DEBUG_DRIVE_3
        END
        POPUP "&Edition"
        BEGIN
            MENUITEM "DOKE <address> [<value>]",    ID_DEBUG_DOKE
            MENUITEM "E|POKE [<address> [<value>]]", ID_DEBUG_POKE
            MENUITEM "FPOKE <address> <value>",     ID_DEBUG_FPOKE
            MENUITEM "WRITEPORT <port>|CTRL|DATA <value>", 
                                                    ID_DEBUG_WRITEPORT
        END
        POPUP "&Visualiser"
        BEGIN
            MENUITEM "= [<address>]",               ID_DEBUG_EQUALS
            MENUITEM "COVER [<reporttype>]",        ID_DEBUG_COVER
            MENUITEM "D|PEEK <start-addr> [<end-addr>]", ID_DEBUG_PEEK
            MENUITEM "DIS [<start-addr> [<end-addr>]]", ID_DEBUG_DIS
            MENUITEM "ERROR <number>",              ID_DEBUG_ERROR
            MENUITEM "FPEEK <start-addr> [<end-addr>]", ID_DEBUG_FPEEK
            MENUITEM "HISTORY",                     ID_DEBUG_HISTORY
            MENUITEM "IM [<start-addr> <end-addr>] [<filename>]", 
                                                    ID_DEBUG_IM
            MENUITEM "READPORT <port>|CTRL|DATA",   ID_DEBUG_READPORT
            MENUITEM SEPARATOR
            MENUITEM "V|VIEW BASIC",                ID_DEBUG_VIEW_BASIC
            MENUITEM "V|VIEW BIOS",                 ID_DEBUG_VIEW_BIOS
            MENUITEM "V|VIEW CPU",                  ID_DEBUG_VIEW_CPU
            MENUITEM "V|VIEW PSG",                  ID_DEBUG_VIEW_PSG
            MENUITEM "V|VIEW RAM",                  ID_DEBUG_VIEW_RAM
            MENUITEM "V|VIEW SCRN",                 ID_DEBUG_VIEW_SCRN
            MENUITEM "V|VIEW UDG",                  ID_DEBUG_VIEW_UDG
            MENUITEM "V|VIEW XVI",                  ID_DEBUG_VIEW_XVI
        END
        POPUP "&Log"
        BEGIN
            MENUITEM "L A",                         ID_DEBUG_L_A
            MENUITEM "L B",                         ID_DEBUG_L_B
            MENUITEM "L C",                         ID_DEBUG_L_C
            MENUITEM "L I",                         ID_DEBUG_L_I
            MENUITEM "L N",                         ID_DEBUG_L_N
            MENUITEM "L S",                         ID_DEBUG_L_S
            MENUITEM SEPARATOR
            MENUITEM "PL",                          ID_DEBUG_PL
            MENUITEM "T",                           ID_DEBUG_T
        END
        POPUP "&Run"
        BEGIN
            MENUITEM "G|P [<address>]",             ID_DEBUG_G
            MENUITEM "GI",                          ID_DEBUG_GI
            MENUITEM "I",                           ID_DEBUG_I
            MENUITEM "J|JUMP <address>",            ID_DEBUG_JUMP
            MENUITEM "O",                           ID_DEBUG_O
            MENUITEM "S",                           ID_DEBUG_S
            MENUITEM SEPARATOR
            MENUITEM "R <number>",                  ID_DEBUG_R
            MENUITEM "R F",                         ID_DEBUG_R_F
            MENUITEM "R I",                         ID_DEBUG_R_I
            MENUITEM "R L",                         ID_DEBUG_R_L
            MENUITEM "R R",                         ID_DEBUG_R_R
            MENUITEM "R S",                         ID_DEBUG_R_S
        END
        POPUP "&Breakpoints"
        BEGIN
            MENUITEM "BP <start-addr> [<end-addr>] [<addr/reg> <condition> <value>]", 
                                                    ID_DEBUG_BP
            MENUITEM "BC [<start-addr> [<end-addr>]]", ID_DEBUG_BC
            MENUITEM "BL",                          ID_DEBUG_BL
            MENUITEM SEPARATOR
            MENUITEM "FP <start-addr> [<end-addr>]", ID_DEBUG_FP
            MENUITEM "FC [<start-addr> [<end-addr>]]", ID_DEBUG_FC
            MENUITEM "FL",                          ID_DEBUG_FL
            MENUITEM SEPARATOR
            MENUITEM "IP [<start-port> [<end-port>] [<addr/reg> <condition> <value>]]", 
                                                    ID_DEBUG_IP
            MENUITEM "IC [<start-port> [<end-port>]]", ID_DEBUG_IC
            MENUITEM "IL",                          ID_DEBUG_IL
            MENUITEM SEPARATOR
            MENUITEM "WP <start-addr> [<end-addr>] [<addr/reg> <condition> <value>]", 
                                                    ID_DEBUG_WP
            MENUITEM "WC [<start-addr> [<end-addr>]]", ID_DEBUG_WC
            MENUITEM "WL",                          ID_DEBUG_WL
            MENUITEM SEPARATOR
            MENUITEM "PB",                          ID_DEBUG_PB
            MENUITEM "WR",                          ID_DEBUG_WR
            MENUITEM SEPARATOR
            MENUITEM "WW NONE",                     ID_DEBUG_WW_NONE
            MENUITEM "WW SOME",                     ID_DEBUG_WW_SOME
            MENUITEM "WW ALL",                      ID_DEBUG_WW_ALL
        END
        POPUP "&Symbols"
        BEGIN
            MENUITEM "CLEARSYM [<label>]",          ID_DEBUG_CLEARSYM
            MENUITEM "DEFSYM <label> <address> [C|D|P|U]", ID_DEBUG_DEFSYM
            MENUITEM "LOADSYM [<filename>]",        ID_DEBUG_LOADSYM
            MENUITEM "SAVESYM <filename>",          ID_DEBUG_SAVESYM
        END
        POPUP "Ou&tils"
        BEGIN
            MENUITEM "CO|COMP <1st-start> <1st-end> <2nd-start>", 
                                                    ID_DEBUG_COMP
            MENUITEM "COPY|MOVE <source-start> <source-end> <target-start>", 
                                                    ID_DEBUG_COPY
            MENUITEM "FILL <start-addr> <end-addr> <value>", ID_DEBUG_FILL
            MENUITEM "FIND [[<start-addr> <end-addr>] <value>]", 
                                                    ID_DEBUG_FIND
            MENUITEM "REL <source-addr> [*]<target-addr>", ID_DEBUG_REL
            MENUITEM "SWAP <1st-start> <1st-end> <2nd-start>", ID_DEBUG_SWAP
            MENUITEM "TRAIN [<value>]",             ID_DEBUG_TRAIN
        END
        POPUP "&Options"
        BEGIN
            MENUITEM "BASE 2|% (binary)",           ID_DEBUG_BASE_BINARY
            MENUITEM "BASE 8|@ (octal)",            ID_DEBUG_BASE_OCTAL
            MENUITEM "BASE 10|! (decimal)",         ID_DEBUG_BASE_DECIMAL
            MENUITEM "BASE 16|$ (hexadecimal)",     ID_DEBUG_BASE_HEX
            MENUITEM SEPARATOR
            MENUITEM "CPU 0 (2650/2650A)",          ID_DEBUG_CPU_0
            MENUITEM "CPU 1 (2650B)",               ID_DEBUG_CPU_1
